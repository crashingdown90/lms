generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skpd {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String        @id @default(cuid())
  nip          String        @unique
  name         String
  passwordHash String
  role         String        @default("PEGAWAI") // PEGAWAI, ADMIN_SKPD, SUPER_ADMIN
  
  jenisJabatan      String?
  golongan          String?
  tingkatPendidikan String?
  programStudi      String?
  eselon            String?
  jenisKelamin      String?

  skpdId       String
  skpd         Skpd          @relation(fields: [skpdId], references: [id])
  totalJp      Int           @default(0)
  targetJp     Int           @default(20)
  status       String        @default("AKTIF") // AKTIF, CUTI, PENSIUN, NONAKTIF
  progress     Progress[]
  certificates Certificate[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lastLogin    DateTime?
}

model Course {
  id           String        @id @default(cuid())
  title        String
  category     String
  description  String?
  videoUrl     String?
  jpCredit     Int           @default(2)
  status       String        @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  progress     Progress[]
  certificates Certificate[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  status    String   @default("BELUM_MULAI") // BELUM_MULAI, SEDANG_BELAJAR, SELESAI
  score     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
}

model Certificate {
  id         String   @id @default(cuid())
  certNumber String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id])
  issueDate  DateTime @default(now())
  status     String   @default("MENUNGGU") // MENUNGGU, DISETUJUI, DITOLAK
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
